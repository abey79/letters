out := "build"
scad := "wd2_adapter.scad"
name := "wd2_adapter"
openscad := env_var_or_default("OPENSCAD", `command -v openscad 2>/dev/null || command -v OpenSCAD 2>/dev/null || echo /Applications/OpenSCAD.app/Contents/MacOS/OpenSCAD`)

default: all

# Render printable artifacts (STL + 3MF) into build/.
all:
    @mkdir -p {{out}}
    @echo "  {{name}} -> {{out}}/{{name}}.stl"
    @{{openscad}} -q -o {{out}}/{{name}}.stl {{scad}}
    @echo "  {{name}} -> {{out}}/{{name}}.3mf"
    @{{openscad}} -q -o {{out}}/{{name}}.3mf {{scad}}

# Render README images (preview + axial cutaway) via OpenSCAD + PyVista.
docs:
    @mkdir -p {{out}}/docs
    @{{openscad}} -q -o {{out}}/docs/{{name}}.stl {{scad}}
    @uv run docs/render.py {{out}}/docs/{{name}}.stl {{out}}/docs/preview.png preview
    @uv run docs/render.py {{out}}/docs/{{name}}.stl {{out}}/docs/cutaway.png cutaway

# Quick OpenSCAD PNG (needs an X display when run locally).
preview:
    @mkdir -p {{out}}
    @{{openscad}} -q -o {{out}}/{{name}}.png \
        --imgsize=800,800 --colorscheme=Tomorrow {{scad}}

clean:
    rm -rf {{out}}
